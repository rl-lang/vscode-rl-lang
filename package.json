{
  "name": "vscode-rl-lang",
  "displayName": "rl-lang",
  "description": "Language support for rl-lang: syntax highlighting, diagnostics/hover/completions (LSP), and run/check/dev commands",
  "version": "0.2.0",
  "publisher": "MohamedGonem",
  "repository": {
    "type": "git",
    "url": "https://github.com/rl-lang/vscode-rl-lang"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onLanguage:rl",
    "workspaceContains:rl.toml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "rl",
        "aliases": [
          "rl-lang",
          "rl",
          "RL"
        ],
        "extensions": [
          ".rl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "rl",
        "scopeName": "source.rl",
        "path": "./syntaxes/rl.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "rl.run",
        "title": "rl: Run File",
        "icon": "$(play)"
      },
      {
        "command": "rl.check",
        "title": "rl: Check File",
        "icon": "$(check)"
      },
      {
        "command": "rl.dev",
        "title": "rl: Dev (run project)",
        "icon": "$(rocket)"
      },
      {
        "command": "rl.format",
        "title": "rl: Format File",
        "icon": "$(edit)"
      },
      {
        "command": "rl.new",
        "title": "rl: New Project"
      },
      {
        "command": "rl.compile",
        "title": "rl: Compile to Bytecode (.rlc)"
      },
      {
        "command": "rl.package",
        "title": "rl: Package as Binary"
      },
      {
        "command": "rl.repl",
        "title": "rl: Open REPL"
      },
      {
        "command": "rl.docs",
        "title": "rl: Open Docs"
      },
      {
        "command": "rl.workflows",
        "title": "rl: Generate GitHub Actions Workflows"
      },
      {
        "command": "rl.restartServer",
        "title": "rl: Restart Language Server"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "rl.run",
          "when": "resourceExtname == .rl",
          "group": "navigation@1"
        },
        {
          "command": "rl.check",
          "when": "resourceExtname == .rl",
          "group": "navigation@2"
        },
        {
          "command": "rl.dev",
          "when": "resourceExtname == .rl",
          "group": "navigation@3"
        },
        {
          "command": "rl.format",
          "when": "resourceExtname == .rl",
          "group": "navigation@4"
        }
      ],
      "explorer/context": [
        {
          "command": "rl.run",
          "when": "resourceExtname == .rl",
          "group": "rl@1"
        },
        {
          "command": "rl.check",
          "when": "resourceExtname == .rl",
          "group": "rl@2"
        },
        {
          "command": "rl.format",
          "when": "resourceExtname == .rl",
          "group": "rl@3"
        },
        {
          "command": "rl.compile",
          "when": "resourceExtname == .rl",
          "group": "rl@4"
        },
        {
          "command": "rl.package",
          "when": "resourceExtname == .rl",
          "group": "rl@5"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
