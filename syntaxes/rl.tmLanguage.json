{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "rl",
  "scopeName": "source.rl",
  "fileTypes": ["rl"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#attributes" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#literals" },
    { "include": "#match" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "include": "#block-comment" },
        {
          "name": "comment.line.documentation.rl",
          "match": "///.*$"
        },
        {
          "name": "comment.line.double-slash.rl",
          "match": "//.*$"
        }
      ]
    },
    "block-comment": {
      "name": "comment.block.rl",
      "begin": "/\\*",
      "end": "\\*/",
      "patterns": [{ "include": "#block-comment" }]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.rl",
          "begin": "(!#)\\s*(\\[)",
          "beginCaptures": {
            "1": { "name": "keyword.operator.bang.rl" },
            "2": { "name": "punctuation.bracket.rl" }
          },
          "end": "(\\])",
          "endCaptures": {
            "1": { "name": "punctuation.bracket.rl" }
          },
          "patterns": [
            {
              "name": "entity.name.tag.rl",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
            },
            { "include": "#literals" },
            { "include": "#punctuation" }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.rl",
          "match": "\\b(if|else|while|for|in|return|match|break|continue|loop)\\b"
        },
        {
          "name": "keyword.declaration.rl",
          "match": "\\b(fn|dec|CONST|const|tag|record|impl)\\b"
        },
        {
          "name": "keyword.import.rl",
          "match": "\\b(get|from)\\b"
        },
        {
          "name": "keyword.operator.logical.rl",
          "match": "\\b(and|or)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.builtin.rl",
          "match": "\\b(int|float|bool|string|char|arr|set|map)\\b"
        },
        {
          "comment": "tag Name { ... } / record Name { ... } declaration name",
          "match": "\\b(tag|record)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.rl" },
            "2": { "name": "entity.name.type.rl" }
          }
        },
        {
          "comment": "impl Name { ... } target type",
          "match": "\\b(impl)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.rl" },
            "2": { "name": "entity.name.type.rl" }
          }
        },
        {
          "comment": "type in declaration position: dec Type name = ..., CONST Type name = ...",
          "match": "\\b(dec|CONST)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.rl" },
            "2": { "name": "entity.name.type.rl" }
          }
        },
        {
          "comment": "arr[Type], set[Type], map[Key, Value] element/key/value types",
          "match": "\\b(arr|set|map)(\\[)",
          "captures": {
            "1": { "name": "support.type.builtin.rl" },
            "2": { "name": "punctuation.bracket.rl" }
          }
        },
        {
          "comment": "PascalCase identifier used as a type name (struct literal, variant tag, type reference)",
          "name": "entity.name.type.rl",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b(?=\\s*\\{)"
        },
        {
          "comment": "Tag.Variant  (variant_pattern / enum-style field access)",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)(\\.)([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.type.rl" },
            "2": { "name": "punctuation.delimiter.rl" },
            "3": { "name": "variable.other.enummember.rl" }
          }
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "string.quoted.double.rl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.rl",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.rl",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.rl",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "constant.numeric.float.rl",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.rl",
          "match": "\\b[0-9]+\\b"
        },
        {
          "name": "constant.language.boolean.rl",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.rl",
          "match": "\\bnull\\b"
        }
      ]
    },
    "match": {
      "patterns": [
        {
          "name": "constant.language.wildcard.rl",
          "match": "(?<![a-zA-Z0-9_])_(?![a-zA-Z0-9_])"
        },
        {
          "name": "keyword.operator.arrow.rl",
          "match": "=>"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.rl",
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.rl" },
            "2": { "name": "entity.name.function.rl" }
          }
        },
        {
          "name": "entity.name.function.call.rl",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.rl" }
          }
        },
        {
          "name": "entity.name.function.method.rl",
          "match": "\\.([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.method.rl" }
          }
        },
        {
          "comment": "field access: expr.field (non-call, non-enum-variant)",
          "match": "(\\.)([a-z_][a-zA-Z0-9_]*)\\b(?!\\s*\\()",
          "captures": {
            "1": { "name": "punctuation.delimiter.rl" },
            "2": { "name": "variable.other.property.rl" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.rl",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.rl",
          "match": "(\\+=|-=|\\*=|/=|=)"
        },
        {
          "name": "keyword.operator.arithmetic.rl",
          "match": "(\\+|-|\\*|/)"
        },
        {
          "name": "keyword.operator.arrow.rl",
          "match": "->"
        },
        {
          "name": "keyword.operator.range.rl",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.path.rl",
          "match": "::"
        },
        {
          "name": "keyword.operator.propagate.rl",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.bang.rl",
          "match": "!#|!"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.bracket.rl",
          "match": "[()\\[\\]{}]"
        },
        {
          "name": "punctuation.separator.rl",
          "match": ","
        },
        {
          "name": "punctuation.delimiter.rl",
          "match": "\\."
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.rl",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
